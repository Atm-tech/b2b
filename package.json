{
  "name": "aapoorti-b2b-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "vercel:install": "npm install --workspace @aapoorti-b2b/domain --workspace @aapoorti-b2b/web",
    "vercel-build": "npm run build -w packages/domain && npm run build -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
